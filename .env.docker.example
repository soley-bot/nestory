# Browsers on Windows and the Nestory server inside Docker can both resolve
# host.docker.internal to the local Supabase gateway.
NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
APP_ROOT_DOMAIN=localhost
APP_RESERVED_SUBDOMAINS=www,app,api
